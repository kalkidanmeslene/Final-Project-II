# Local default: PostgreSQL 16 often listens on 5433 when 17 uses 5432
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5433/hibir_events?schema=public"

# MUST be >= 32 characters
AUTH_JWT_SECRET="replace-with-long-random-secret-at-least-32-chars"
AUTH_JWT_ISSUER="hibir-events"
AUTH_JWT_AUDIENCE="hibir-events:web"

AUTH_ACCESS_TOKEN_TTL_SECONDS="3600"
AUTH_REFRESH_TOKEN_TTL_SECONDS="2592000"

APP_BASE_URL="http://localhost:3000"

# Email — required for ticket QR, event updates, announcements, password reset
EMAIL_ENABLED="true"
EMAIL_PROVIDER="smtp"
EMAIL_FROM="Hibir Events <your-sender@gmail.com>"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-sender@gmail.com"
SMTP_PASS="your-google-app-password"
SMTP_FROM="Hibir Events <your-sender@gmail.com>"
RESEND_API_KEY=""

CRON_SECRET="dev-cron-secret-change-me"


AI_ENABLED="true"
AI_PROVIDER="auto"
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_BASE_URL="https://api.groq.com/openai/v1"
AI_REQUEST_TIMEOUT_MS="20000"
